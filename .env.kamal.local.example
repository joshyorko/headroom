# Copy to .env.kamal.local and fill when Harvester VM IP is known.
KAMAL_HOST=headroom-mk1
KAMAL_PUBLIC_HOST=headroom.example.test
KAMAL_SSH_USER=kdlocpanda
KAMAL_STORAGE_PATH=/home/kdlocpanda/headroom-data
KAMAL_ARCH=amd64
KAMAL_PROXY_HTTP_PORT=80
KAMAL_IMAGE=joshyorko/headroom
KAMAL_REGISTRY_SERVER=ghcr.io
KAMAL_REGISTRY_USERNAME=joshyorko

HEADROOM_PORT=8787
HEADROOM_TARGET_RATIO=0.4
HEADROOM_MEMORY_BACKEND=qdrant-neo4j
HEADROOM_MEMORY_TOP_K=5
HEADROOM_MIN_EVIDENCE=10
HEADROOM_MEMORY_CONTEXT_TIMEOUT_SECONDS=1.0
# Leave unset to let /home/nonroot/.headroom/verbosity.json from
# `headroom learn --verbosity --apply` control the deployed proxy.
# Set only for a manual override:
# HEADROOM_VERBOSITY_LEVEL=2

# Used by .kamal/secrets, not committed with real values.
KAMAL_REGISTRY_PASSWORD=ghp_with_packages_write
NEO4J_AUTH=neo4j/change-me-before-deploy
HEADROOM_NEO4J_PASSWORD=change-me-before-deploy
GITHUB_TOKEN=github_pat_or_ghp_token
OPENAI_API_KEY=sk-proj-or-service-key
