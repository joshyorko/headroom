#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

usage() {
  cat <<'EOF'
Usage: scripts/headroom-rebuild-install

Build Headroom in the repo-local Dagger module, export the wheel bundle, install
the fresh CLI into the host uv tool environment, and verify `headroom --version`.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -ne 0 ]]; then
  usage >&2
  exit 2
fi

ensure_brew_tool() {
  local command_name="$1"
  local formula="$2"

  if command -v "$command_name" >/dev/null 2>&1; then
    return
  fi

  if ! command -v brew >/dev/null 2>&1; then
    echo "Homebrew is required to install missing tool $command_name; install Homebrew and rerun this script." >&2
    exit 127
  fi

  echo "$command_name is missing; installing Homebrew formula $formula..." >&2
  brew install "$formula"

  if ! command -v "$command_name" >/dev/null 2>&1; then
    echo "Homebrew installed $formula, but $command_name is still unavailable on PATH." >&2
    exit 127
  fi
}

ensure_brew_tool dagger dagger
ensure_brew_tool uv uv

rm -rf dist/headroom-dev
dagger call dev-install-script export --path dist/headroom-dev
dist/headroom-dev/install-headroom-from-wheel
